# SonarFT API — environment template
# Copy to .env and fill in values

# Auth (choose one):
# Option A — Netlify Identity JWT validation
NETLIFY_SITE_URL=https://your-site.netlify.app
# Option B — Static token (simpler, non-Netlify deployments)
# SONARFT_API_TOKEN=your-secret-token

# CORS — comma-separated allowed origins
CORS_ORIGINS=https://your-frontend.com

# Bot limits
MAX_BOTS_PER_CLIENT=5

# Data directory
DATA_DIR=../bot/sonarftdata

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
