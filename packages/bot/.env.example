# SonarFT Bot — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Exchange API Keys
# Replace EXCHANGE with the exchange ID in uppercase (e.g. BINANCE, OKX, BITFINEX).
# Required for live trading only. Not needed for simulation mode.
# ---------------------------------------------------------------------------

# BINANCE_API_KEY=your_binance_api_key
# BINANCE_SECRET=your_binance_secret_key
# BINANCE_PASSWORD=  # optional — only required for exchanges that use a passphrase

# OKX_API_KEY=your_okx_api_key
# OKX_SECRET=your_okx_secret_key
# OKX_PASSWORD=your_okx_passphrase  # required for OKX

# BITFINEX_API_KEY=your_bitfinex_api_key
# BITFINEX_SECRET=your_bitfinex_secret_key

# ---------------------------------------------------------------------------
# Live Trading Safety Gate
# REQUIRED to enable live trading. Without this, is_simulating_trade=0
# in config will raise BotCreationError at startup.
# ---------------------------------------------------------------------------

# SONARFT_ALLOW_LIVE=true

# ---------------------------------------------------------------------------
# Circuit Breaker
# ---------------------------------------------------------------------------

# SONARFT_MAX_FAILURES=5        # consecutive search failures before halting (default: 5)
# SONARFT_BACKOFF_BASE=30       # backoff seconds per failure level (default: 30)

# ---------------------------------------------------------------------------
# Trading Cycle
# ---------------------------------------------------------------------------

# SONARFT_CYCLE_SLEEP_MIN=6     # minimum seconds between cycles (default: 6)
# SONARFT_CYCLE_SLEEP_MAX=18    # maximum seconds between cycles (default: 18)

# ---------------------------------------------------------------------------
# Concurrency & Rate Limiting
# ---------------------------------------------------------------------------

# SONARFT_MAX_CONCURRENT_TRADES=10  # max in-flight trade tasks per bot (default: 10)

# ---------------------------------------------------------------------------
# Fee Refresh
# ---------------------------------------------------------------------------

# SONARFT_FEE_REFRESH_INTERVAL=86400  # fee refresh interval in seconds (default: 86400 = 24h)

# ---------------------------------------------------------------------------
# Financial Calculation
# ---------------------------------------------------------------------------

# SONARFT_FEE_ROUNDING=HALF_UP  # fee rounding mode: HALF_EVEN (default) or HALF_UP

# ---------------------------------------------------------------------------
# Alerting
# ---------------------------------------------------------------------------

# SONARFT_ALERT_WEBHOOK=https://hooks.slack.com/services/...
# Webhook URL for critical alerts (circuit breaker, unhedged positions, cancel failures).
# Supports Slack, Discord, Teams, or any HTTP POST webhook.

# ---------------------------------------------------------------------------
# Database Backup
# ---------------------------------------------------------------------------

# SONARFT_BACKUP_INTERVAL=86400  # backup interval in seconds (default: 86400 = 24h)
#                                # set to 0 to disable automated backups
# SONARFT_BACKUP_DIR=            # backup destination directory
#                                # default: sonarftdata/backups/ (separate from source DB)
#                                # set to a path on a different disk/volume to protect
#                                # against disk failure destroying both DB and backups
