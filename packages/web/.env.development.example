# Development environment template
# Copy to .env.development and set your local values
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/api/v1/ws

# Skip Netlify Identity login — auto-injects a dev user
# Set to "true" for local development without auth
VITE_DEV_AUTH_BYPASS=true

# Optional: Web Vitals reporting endpoint
# In development, vitals are logged to console regardless of this setting.
# VITE_VITALS_URL=

# Idle session timeout in milliseconds (default: 1800000 = 30 minutes)
# Set lower for testing, e.g. 60000 = 1 minute
# VITE_IDLE_TIMEOUT_MS=1800000
