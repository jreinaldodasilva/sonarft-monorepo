# Production environment template
# Copy to .env.production and set your deployment URLs

VITE_API_URL=https://your-sonarft-api-domain.com
VITE_WS_URL=wss://your-sonarft-api-domain.com/ws

# Optional: Web Vitals reporting endpoint (POST, JSON body with name/value/rating/delta/id/url/ts)
# Set to your analytics endpoint to enable real-user performance monitoring.
# Leave unset to disable vitals reporting.
# VITE_VITALS_URL=https://your-analytics-endpoint.com/vitals

# Optional: Idle session timeout in milliseconds (default: 1800000 = 30 minutes)
# VITE_IDLE_TIMEOUT_MS=1800000
